{
  "name": "projecttimetracker",
  "description": "Project Time Tracker",
  "version": "1.0.5",
  "main": "main.mjs",
  "scripts": {
    "start:web": "webpack serve --config webpack.dev.js",
    "start:electron": "ELECTRON_ENABLE_LOGGING=1 MODE=development electron .",
    "dev": "concurrently \"npm run start:web\" \"npm run start:electron\"",
    "build:web": "webpack --mode production --config webpack.prod.js",
    "build:electron": "electron-builder",
    "build": "npm run build:web && npm run build:electron"
  },
  "build": {
    "appId": "com.charles-gong.projecttimetracker",
    "productName": "Project Time Tracker",
    "directories": {
      "output": "app"
    },
    "win": {
      "target": "portable",
      "icon": "public/icon.png"
    }
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@ant-design/icons": "^5.5.1",
    "@hello-pangea/dnd": "^17.0.0",
    "antd": "^5.21.6",
    "css-loader": "^7.1.2",
    "dayjs": "^1.11.13",
    "electron-reload": "^2.0.0-alpha.1",
    "lowdb": "^7.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "style-loader": "^4.0.0",
    "uuid": "^11.0.2",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.25.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "babel-loader": "^9.2.1",
    "concurrently": "^9.0.1",
    "electron": "^33.0.2",
    "electron-builder": "^25.1.8",
    "html-webpack-plugin": "^5.6.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "webpack": "^5.95.0",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  }
}
